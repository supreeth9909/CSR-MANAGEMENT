# Gmail SMTP Configuration
# Copy this file to .env and fill in your actual credentials

# Your Gmail address (must have 2-factor authentication enabled)
EMAIL_HOST_USER=your-email@gmail.com

# Your Gmail App Password (not your regular password!)
# Get this from Google Account settings -> Security -> 2-Step Verification -> App passwords
EMAIL_HOST_PASSWORD=your-app-password-here

# Optional: Custom from email address (defaults to EMAIL_HOST_USER if not set)
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# Optional: Override default SMTP settings
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
